            "interceptor_js": "(()=>{try{if(window.location.origin!=='https://platform.qianwenai.com')return'ok-not-target';const TS=['/tokenplan/personal/api/v2/subscription','/tokenplan/personal/api/v2/quota-config','/tokenplan/personal/api/v2/usage'];const I=window.__TAURI_INTERNALS__.invoke;const m=u=>TS.some(t=>u.includes(t));const oF=window.fetch;window.fetch=async function(...a){const r=await oF.apply(this,a);const u=typeof a[0]==='string'?a[0]:a[0]?.url||'';if(m(u)){r.clone().text().then(b=>{I('handle_intercepted_response',{channelId:'qwen',url:u,body:b}).catch(()=>{});}).catch(()=>{});}return r;};const OX=window.XMLHttpRequest;window.XMLHttpRequest=function(){const x=new OX();const oo=x.open;x.open=function(m,u){this._url=u;return oo.apply(this,arguments);};x.addEventListener('readystatechange',()=>{if(x.readyState===4&&x.status===200&&m(x._url||'')){I('handle_intercepted_response',{channelId:'qwen',url:x._url,body:x.responseText}).catch(()=>{});}});return x;};return'ok-injected';}catch(e){return'err:'+e.message;}})();",
            "extractor_js": "function extract(bundle){try{const sub=bundle?.subscription?.data?.DataV2?.data?.data||{};const quota=bundle?.quota_config?.data?.DataV2?.data?.data||{};const usage=bundle?.usage?.data?.DataV2?.data?.data||{};const code=sub.specCode||'standard';const tier=quota[code]||quota.standard||{};const total=tier.weekly!=null?Number(tier.weekly):null;const pct=usage.per1WeekPercentage!=null?Number(usage.per1WeekPercentage):null;if(total==null||pct==null)return null;const used=Math.round(total*pct);return{balance:null,currency:null,plan_name:'Token Plan 个人版('+code+')',token_total:total,token_used:used,token_remaining:Math.max(0,total-used),token_expire_at:sub.endTime?new Date(sub.endTime).toISOString():null};}catch(e){return null;}}",
            "aggregate": true
          }
        }
