        "scrape": {
          "token_pack": {
            "console_url": "https://longcat.chat/platform/usage?tab=token",
            "interceptor_js": "(()=>{try{if(window.location.origin!=='https://longcat.chat')return'ok-not-target';const T='/api/pay/quota/metering/token-packs/summary';const I=window.__TAURI_INTERNALS__.invoke;const m=u=>u.includes(T);const oF=window.fetch;window.fetch=async function(...a){const r=await oF.apply(this,a);const u=typeof a[0]==='string'?a[0]:a[0]?.url||'';if(m(u)){r.clone().text().then(b=>{I('handle_intercepted_response',{channelId:'longcat',url:u,body:b}).catch(()=>{});}).catch(()=>{});}return r;};const OX=window.XMLHttpRequest;window.XMLHttpRequest=function(){const x=new OX();const oo=x.open;x.open=function(m,u){this._url=u;return oo.apply(this,arguments);};x.addEventListener('readystatechange',()=>{if(x.readyState===4&&x.status===200&&m(x._url||'')){I('handle_intercepted_response',{channelId:'longcat',url:x._url,body:x.responseText}).catch(()=>{});}});return x;};return'ok-injected';}catch(e){return'err:'+e.message;}})();",
            "extractor_js": "function extract(raw){try{const d=raw?.data||raw;const lots=[d.currentLot,...(d.otherLots||[])].filter(Boolean);if(!lots.length)return null;let t=0,u=0,r=0,e=null;for(const l of lots){t+=l.totalToken||0;u+=l.consumedToken||0;r+=l.remainingToken||0;if(l.expireTime&&(!e||l.expireTime<e))e=l.expireTime;}return{balance:null,currency:null,plan_name:'LongCat 资源包',token_total:t||null,token_used:u||null,token_remaining:r||null,token_expire_at:e};}catch(e){return null;}}"
          },
          "pay_as_you_go": {
            "console_url": "https://longcat.chat/platform/usage?tab=api",
            "interceptor_js": "(()=>{try{if(window.location.origin!=='https://longcat.chat')return'ok-not-target';const T='/api/pay/quota/metering/api-usage/summary';const I=window.__TAURI_INTERNALS__.invoke;const m=u=>u.includes(T);const oF=window.fetch;window.fetch=async function(...a){const r=await oF.apply(this,a);const u=typeof a[0]==='string'?a[0]:a[0]?.url||'';if(m(u)){r.clone().text().then(b=>{I('handle_intercepted_response',{channelId:'longcat',url:u,body:b}).catch(()=>{});}).catch(()=>{});}return r;};const OX=window.XMLHttpRequest;window.XMLHttpRequest=function(){const x=new OX();const oo=x.open;x.open=function(m,u){this._url=u;return oo.apply(this,arguments);};x.addEventListener('readystatechange',()=>{if(x.readyState===4&&x.status===200&&m(x._url||'')){I('handle_intercepted_response',{channelId:'longcat',url:x._url,body:x.responseText}).catch(()=>{});}});return x;};return'ok-injected';}catch(e){return'err:'+e.message;}})();",
            "extractor_js": "function extract(raw){try{const d=raw?.data||raw;const c=d.paygoBalanceCent;if(c==null)return null;const y=Math.round((Number(c)/100)*100)/100;const cur=d.paygoBalance?.primary?.currency||'CNY';return{balance:y,currency:cur,plan_name:'LongCat 按量付费',token_total:null,token_used:null,token_remaining:null,token_expire_at:null};}catch(e){return null;}}"
          }
