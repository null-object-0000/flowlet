{
  "ua_rules": [
    {
      "id": "opencode",
      "pattern": "opencode/",
      "name": "OpenCode",
      "enabled": true
    },
    {
      "id": "claude-code",
      "pattern": "claude-cli/",
      "name": "Claude Code",
      "enabled": true
    },
    {
      "id": "flowlet",
      "pattern": "Flowlet/",
      "name": "Flowlet",
      "enabled": true
    }
  ],
  "log_capture": {
    "capture_req_headers": true,
    "capture_req_body": true,
    "capture_res_headers": true,
    "capture_res_body": true,
    "max_body_bytes": 1048576,
    "redact_sensitive_headers": false,
    "body_retention_days": 3,
    "body_max_size_mb": 128,
    "body_prune_ratio": 0.1
  },
  "bind": {
    "host": "127.0.0.1",
    "port": 18640
  },
