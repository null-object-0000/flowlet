{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowlet",
  "version": "0.1.0",
  "identifier": "local.flowlet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "Flowlet",
        "userAgent": "Flowlet/0.1.0",
        "width": 1200,
        "height": 720,
        "minWidth": 1200,
        "minHeight": 720,
        "maxWidth": 1200,
        "maxHeight": 720,
        "resizable": false,
        "maximizable": false,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../config.json": "config.json"
    }
  }
}
