{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowlet",
  "version": "0.1.0",
  "identifier": "local.flowlet.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flowlet",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/tray.png",
      "iconAsTemplate": true,
      "title": "Flowlet",
      "tooltip": "Flowlet - 本地 AI 请求路由"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
