{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flowlet",
  "version": "0.1.0",
  "identifier": "local.flowlet.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Flowlet",
        "width": 1120,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../config.json"
    ]
  }
}
